{
  "source_directory": ".",
  "organize_by": "extension",
  "create_subdirectories": true,
  "move_files": false,
  "rules": {
    "documents": [
      ".pdf",
      ".doc",
      ".docx",
      ".txt",
      ".xlsx",
      ".xls",
      ".ppt",
      ".pptx",
      ".odt",
      ".rtf"
    ],
    "images": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".bmp",
      ".svg",
      ".ico",
      ".tiff",
      ".webp"
    ],
    "videos": [
      ".mp4",
      ".mkv",
      ".avi",
      ".mov",
      ".flv",
      ".wmv",
      ".webm",
      ".m4v"
    ],
    "audio": [
      ".mp3",
      ".wav",
      ".flac",
      ".aac",
      ".m4a",
      ".wma",
      ".ogg",
      ".alac"
    ],
    "archives": [
      ".zip",
      ".rar",
      ".7z",
      ".tar",
      ".gz",
      ".bz2",
      ".iso"
    ],
    "code": [
      ".py",
      ".js",
      ".ts",
      ".jsx",
      ".tsx",
      ".cpp",
      ".c",
      ".h",
      ".java",
      ".html",
      ".css",
      ".json",
      ".xml",
      ".yaml",
      ".yml",
      ".go",
      ".rs",
      ".php",
      ".rb",
      ".sql"
    ],
    "executables": [
      ".exe",
      ".msi",
      ".app",
      ".dmg",
      ".sh",
      ".bat",
      ".cmd"
    ],
    "data": [
      ".csv",
      ".db",
      ".sqlite",
      ".json",
      ".sql"
    ]
  }
}
